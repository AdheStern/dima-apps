generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELOS BASE BETTER AUTH
// ============================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  phone         String?
  birthDate     DateTime?
  createdAt     DateTime
  updatedAt     DateTime
  
  // Extensiones para administración
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?

  
  role          String    @default("USER")
  status        String    @default("ACTIVE")
  departmentId  String?
  managerId     String?      // Auto-referencia para jerarquía
  
  // Relaciones Better Auth
  sessions      Session[]
  accounts      Account[]
  
  // Relaciones organizacionales
  department    Department?        @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  manager       User?              @relation("ManagerSubordinates", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates  User[]             @relation("ManagerSubordinates")
  
  // Relaciones con organizaciones
  organizationMembers OrganizationMember[]
  organizationInvitations OrganizationInvitation[]

  @@unique([email])
  @@index([departmentId])
  @@index([managerId])
  @@index([role])
  @@index([status])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ============================================
// MODELOS DE ORGANIZACIÓN (Organization Plugin)
// ============================================

model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  logo      String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      OrganizationMember[]
  invitations  OrganizationInvitation[]

  @@map("organization")
}

model OrganizationMember {
  id             String       @id
  organizationId String
  userId         String
  role           String       @default("MEMBER")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_member")
}

model OrganizationInvitation {
  id             String   @id
  organizationId String
  email          String
  role           String   @default("MEMBER")
  status         String   @default("PENDING")
  inviterId      String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([email])
  @@index([status])
  @@map("organization_invitation")
}

// ============================================
// MODELOS PERSONALIZADOS
// ============================================

model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Department[] @relation("DepartmentHierarchy")
  users       User[]       @relation("UserDepartment")

  @@index([parentId])
  @@map("department")
}

// ============================================
// ENUMS (boilerplate)
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SUPERVISOR
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// ============================================
// PERFIL EXTENDIDO (datos de Microsoft Graph)
// Poblado durante el callback OAuth de Microsoft.
// No usa FK formal para no acoplar con better-auth.
// ============================================

model UserProfile {
  id             String  @id @default(cuid())
  userId         String  @unique // referencia al User.id de better-auth
  department     String?
  officeLocation String? // sede / región del ingeniero
  jobTitle       String?
  managerMsId    String? // Microsoft Object ID del manager
  msObjectId     String? @unique

  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

// ============================================
// SLA
// ============================================

model SlaType {
  id                String @id @default(cuid())
  name              String @unique // "24x7", "8x5", "12x5", etc.
  description       String?
  hoursPerDay       Int
  daysPerWeek       Int
  responseTimeHours Int    // compromiso de primera respuesta en horas

  clients Client[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sla_types")
}

// ============================================
// CLIENTES
// ============================================

model Client {
  id      String  @id @default(cuid())
  name    String
  ruc     String? @unique // RUC / RIF / NIT según el país
  email   String?
  phone   String?
  address String?
  active  Boolean @default(true)

  slaTypeId String
  slaType   SlaType @relation(fields: [slaTypeId], references: [id])

  contacts       ClientContact[]
  hourPackages   ClientHourPackage[]
  supportTickets SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slaTypeId])
  @@map("clients")
}

model ClientContact {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name      String
  position  String? // cargo
  email     String
  phone     String?
  isPrimary Boolean @default(false)

  conformities ClientConformity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("client_contacts")
}

// Historial de paquetes de horas compradas por cliente.
// Horas disponibles = SUM(packages.hours) - SUM(tickets.totalHours WHERE status = COMPLETED)
model ClientHourPackage {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  hours        Decimal   @db.Decimal(10, 2)
  purchaseDate DateTime  @default(now())
  expiryDate   DateTime?
  invoiceRef   String?   // referencia de factura
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("client_hour_packages")
}

// ============================================
// CATÁLOGO DE TIPOS DE SOPORTE
// ============================================

model SupportType {
  id          String  @id @default(cuid())
  name        String  @unique // "Correctivo", "Preventivo", "Instalación", etc.
  description String?
  active      Boolean @default(true)

  tickets SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_types")
}

// ============================================
// SOPORTES
// ============================================

model SupportTicket {
  id           String        @id @default(cuid())
  ticketNumber String        @unique // generado en app: DIMA-2026-00001

  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  supportTypeId String
  supportType   SupportType   @relation(fields: [supportTypeId], references: [id])

  // Referencias a User.id de better-auth sin FK formal
  assignedById String // ingeniero que registra / asigna
  assignedToId String // ingeniero encargado de ejecutar

  shortDescription String
  observations     String?

  startTime DateTime?
  endTime   DateTime?

  // totalHours puede calcularse desde startTime/endTime o ingresarse manualmente.
  // Si se ingresa manualmente, manualHours toma precedencia sobre el cálculo.
  manualHours    Decimal? @db.Decimal(10, 2)
  calculatedHours Decimal? @db.Decimal(10, 2) // persistido al cerrar el ticket
  totalHours     Decimal? @db.Decimal(10, 2)  // campo final: manualHours ?? calculatedHours

  status SupportStatus @default(PENDING)

  documents  SupportDocument[]
  pauseLogs  SupportPauseLog[]
  conformity ClientConformity?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([supportTypeId])
  @@index([assignedToId])
  @@index([assignedById])
  @@index([status])
  @@map("support_tickets")
}

// Trazabilidad de pausas — permite calcular tiempo real trabajado
model SupportPauseLog {
  id              String        @id @default(cuid())
  supportTicketId String
  supportTicket   SupportTicket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  pausedAt  DateTime
  resumedAt DateTime?
  reason    String?

  @@index([supportTicketId])
  @@map("support_pause_logs")
}

// ============================================
// DOCUMENTOS ADJUNTOS
// ============================================

model SupportDocument {
  id              String        @id @default(cuid())
  supportTicketId String
  supportTicket   SupportTicket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  fileName      String
  fileUrl       String   // ruta en storage (S3, filesystem, etc.)
  mimeType      String?
  fileSizeBytes Int?
  uploadedById  String   // User.id de better-auth

  createdAt DateTime @default(now())

  @@index([supportTicketId])
  @@map("support_documents")
}

// ============================================
// CONFORMIDAD DEL CLIENTE (opcional por ticket)
// Flujo: ticket completado → se genera approvalToken
// → se envía email al contacto → cliente aprueba vía link
// ============================================

model ClientConformity {
  id              String           @id @default(cuid())
  supportTicketId String           @unique
  supportTicket   SupportTicket    @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)

  contactId String?
  contact   ClientContact? @relation(fields: [contactId], references: [id])

  status         ConformityStatus @default(PENDING)
  approvalToken  String?          @unique // token enviado por email para aprobar
  tokenExpiresAt DateTime?
  conformityDate DateTime?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_conformities")
}

// ============================================
// ENUMS (sistema de soportes)
// ============================================

enum SupportStatus {
  PENDING   // Pendiente
  REVIEW    // En revisión
  PAUSED    // Pausado
  COMPLETED // Completado
}

enum ConformityStatus {
  PENDING  // Esperando respuesta del cliente
  APPROVED // Cliente aprobó
  REJECTED // Cliente rechazó / requiere revisión
}